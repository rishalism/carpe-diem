# ---- Core ----
# App environment: development | production
ENVIRONMENT=development

# Database. Default is local SQLite (no setup needed).
# For Supabase Postgres use the connection string from your project settings:
# DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=sqlite:///./carpe_diem.db

# ---- Security / JWT ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- OpenRouter (AI enhancement, Phase 3) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Supabase Storage (attachments, Phase 3) ----
# Leave blank to use the local ./uploads fallback during development.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=carpe-diem

# ---- Google OAuth (Phase 4) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ---- Frontend base URL (for invitation links, emails) ----
FRONTEND_URL=http://localhost:5173

# ---- Redis (optional, deferred) ----
REDIS_URL=
